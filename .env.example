# ============================================================
# LOCAL (développement)
# ============================================================
BULLE_PROVIDER=ollama
BULLE_MODEL=llama3.2
NEXT_PUBLIC_BULLE_URL=http://localhost:3001
BULLE_ADMIN_SECRET=changez-moi-en-local

# ============================================================
# PRODUCTION (Vercel)
# ============================================================
# BULLE_PROVIDER=mistral
# BULLE_MODEL=mistral-small-latest
# MISTRAL_API_KEY=
# BULLE_ADMIN_SECRET=
# BLOB_READ_WRITE_TOKEN=
# CRON_SECRET=
# NEXT_PUBLIC_BULLE_URL=https://bulle-chatbot.vercel.app

# Rate limiting distribué (optionnel — défaut : mémoire par instance serverless)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Quotas par défaut (nouveaux sites)
# BULLE_DEFAULT_MAX_CHATS_PER_DAY=50
# BULLE_DEFAULT_MAX_SYNCS_PER_DAY=3

# Limites
# BULLE_MAX_MESSAGE_LENGTH=2000
# BULLE_MAX_CHAT_MESSAGES=20
# BULLE_CHAT_RATE_LIMIT=30
# BULLE_SYNC_RATE_LIMIT=5

# Site bootstrap
# BULLE_SITE_KEY=
# BULLE_SITE_DOMAINS=localhost,mondomaine.fr
# BULLE_CRAWL_MAX_PAGES=30
# BULLE_INDEX_STALE_HOURS=168
